#!/usr/bin/env python3
import argparse
import asyncio
import importlib.util
import json
import os
import re
import select
import subprocess
import sys
import termios
import time
import tty
from dataclasses import dataclass
from datetime import datetime
from pathlib import Path
from typing import Dict, List, Optional


TEXTUAL_PACKAGE = "textual>=1.0,<2"
BOOTSTRAP_ENV = "AMARAN_TUI_DEPS_BOOTSTRAPPED"


def display_path(path):
    home = str(Path.home())
    absolute = os.path.abspath(os.path.expanduser(str(path)))
    if absolute == home:
        return "~"
    if absolute.startswith(home + os.sep):
        return "~" + absolute[len(home):]
    return absolute


def tui_venv():
    configured = os.environ.get("AMARAN_TUI_VENV")
    if configured:
        return Path(configured).expanduser()
    return Path.home() / "Library" / "Application Support" / "amaran-cli" / "python" / "tui"


def fail_before_textual(message):
    print(f"amaran: {message}", file=sys.stderr)
    raise SystemExit(1)


def ensure_textual_dependency():
    if importlib.util.find_spec("textual") is not None:
        return

    if os.environ.get("AMARAN_TUI_BOOTSTRAP") == "0":
        fail_before_textual(
            "Textual is required for the TUI; install it with "
            f"`python3 -m pip install '{TEXTUAL_PACKAGE}'` or allow bootstrap"
        )

    if os.environ.get(BOOTSTRAP_ENV) == "1":
        fail_before_textual(
            "Textual dependency setup completed, but textual is still not importable"
        )

    venv_dir = tui_venv()
    python_path = venv_dir / "bin" / "python"
    try:
        venv_dir.parent.mkdir(parents=True, mode=0o700, exist_ok=True)
        if not python_path.exists():
            print(f"amaran: preparing TUI environment at {display_path(venv_dir)}", file=sys.stderr)
            subprocess.run([sys.executable, "-m", "venv", str(venv_dir)], check=True)
        print("amaran: installing TUI dependency", file=sys.stderr)
        subprocess.run(
            [
                str(python_path),
                "-m",
                "pip",
                "install",
                "--disable-pip-version-check",
                "--no-cache-dir",
                "-q",
                TEXTUAL_PACKAGE,
            ],
            check=True,
        )
    except subprocess.CalledProcessError as exc:
        fail_before_textual(f"TUI dependency setup failed with exit code {exc.returncode}")
    except OSError as exc:
        fail_before_textual(f"TUI dependency setup failed: {exc}")

    env = dict(os.environ)
    env[BOOTSTRAP_ENV] = "1"
    os.execve(str(python_path), [str(python_path), str(Path(__file__).resolve()), *sys.argv[1:]], env)
    raise AssertionError("unreachable")


def build_parser():
    parser = argparse.ArgumentParser(description="Terminal UI for local amaran fixture control")
    parser.add_argument("--root", required=True)
    parser.add_argument("--state-path", required=True)
    parser.add_argument("--timeout", default="20")
    parser.add_argument("--theme", choices=("auto", "dark", "light"), default="auto")
    return parser


if any(arg in ("--help", "-h") for arg in sys.argv[1:]):
    build_parser().parse_args()
    raise SystemExit(0)

ensure_textual_dependency()

from rich.text import Text
from textual import on
from textual.app import App, ComposeResult
from textual.containers import Horizontal, Vertical
from textual.widgets import Button, DataTable, Footer, Header, Log, Static


class CommandError(Exception):
    def __init__(self, command, message):
        super().__init__(message)
        self.command = command
        self.message = message


@dataclass
class FixtureView:
    name: str
    address: int
    mac: Optional[str] = None
    friendly_name: Optional[str] = None
    source_name: Optional[str] = None
    status: str = "unknown"
    power: str = "unknown"
    intensity: Optional[float] = None
    cct: Optional[int] = None
    gm: Optional[int] = None
    last_error: Optional[str] = None
    pending: bool = False
    updated_at: Optional[datetime] = None

    @property
    def selector(self):
        return self.name or str(self.address)


@dataclass
class SceneView:
    name: str
    fixture_count: int
    captured_at: Optional[str] = None


SCENE_NAME_WIDTH = 14
SCENE_FIXTURE_WIDTH = 9
SCENE_CAPTURED_WIDTH = 19


def scene_row_text(name, fixture_count, captured, selected=False):
    line = (
        f" {name:<{SCENE_NAME_WIDTH}}"
        f"{str(fixture_count):<{SCENE_FIXTURE_WIDTH}}"
        f"{captured:<{SCENE_CAPTURED_WIDTH}}"
    )
    text = Text(line.rstrip())
    if selected:
        text.stylize("reverse")
    return text


class SceneList(Static):
    can_focus = True

    def __init__(self, *args, **kwargs):
        super().__init__(*args, **kwargs)
        self.scenes: List[SceneView] = []
        self.selected_index = 0

    def set_scenes(self, scenes, selected_index=0):
        self.scenes = list(scenes)
        if self.scenes:
            self.selected_index = max(0, min(selected_index, len(self.scenes) - 1))
        else:
            self.selected_index = 0
        self.render_scenes()

    def render_scenes(self):
        lines = [scene_row_text("scene", "fixtures", "captured")]
        for index, scene in enumerate(self.scenes):
            captured = scene.captured_at or "unknown"
            if len(captured) > SCENE_CAPTURED_WIDTH:
                captured = captured[:SCENE_CAPTURED_WIDTH]
            lines.append(
                scene_row_text(
                    scene.name,
                    scene.fixture_count,
                    captured,
                    selected=index == self.selected_index,
                )
            )
        self.update(Text("\n").join(lines))

    def selected_scene(self):
        if not self.scenes:
            return None
        return self.scenes[self.selected_index].name

    def move_selection(self, delta):
        if not self.scenes:
            return
        self.selected_index = max(0, min(len(self.scenes) - 1, self.selected_index + delta))
        self.render_scenes()

    def on_click(self, event):
        row = int(getattr(event, "y", 0)) - 1
        if 0 <= row < len(self.scenes):
            self.selected_index = row
            self.render_scenes()
            app = self.app
            if hasattr(app, "schedule") and hasattr(app, "action_apply_scene"):
                app.schedule(app.action_apply_scene())
            event.stop()

    def on_key(self, event):
        if event.key == "up":
            self.move_selection(-1)
            event.stop()
        elif event.key == "down":
            self.move_selection(1)
            event.stop()
        elif event.key in ("enter", "space"):
            app = self.app
            if hasattr(app, "schedule") and hasattr(app, "action_apply_scene"):
                app.schedule(app.action_apply_scene())
            event.stop()


class SceneNameField(Static):
    can_focus = True

    def __init__(self, *args, placeholder="scene name", **kwargs):
        super().__init__(*args, **kwargs)
        self.placeholder = placeholder
        self.value = ""
        self.cursor = 0

    def on_mount(self):
        self.render_value()

    def render_value(self):
        text = Text()
        if self.value:
            before = self.value[: self.cursor]
            current = self.value[self.cursor : self.cursor + 1]
            after = self.value[self.cursor + 1 :]
            text.append(before)
            if self.has_focus:
                text.append(current or " ", style="reverse")
            else:
                text.append(current)
            text.append(after)
        else:
            if self.has_focus:
                text.append(" ", style="reverse")
            text.append(self.placeholder, style="dim")
        self.update(text)

    def on_focus(self):
        self.render_value()

    def on_blur(self):
        self.render_value()

    def on_key(self, event):
        key = event.key
        character = event.character
        if key == "enter":
            app = self.app
            if hasattr(app, "schedule") and hasattr(app, "capture_scene"):
                app.schedule(app.capture_scene())
            event.stop()
        elif key == "left":
            self.cursor = max(0, self.cursor - 1)
            self.render_value()
            event.stop()
        elif key == "right":
            self.cursor = min(len(self.value), self.cursor + 1)
            self.render_value()
            event.stop()
        elif key == "home":
            self.cursor = 0
            self.render_value()
            event.stop()
        elif key == "end":
            self.cursor = len(self.value)
            self.render_value()
            event.stop()
        elif key == "backspace":
            if self.cursor:
                self.value = self.value[: self.cursor - 1] + self.value[self.cursor :]
                self.cursor -= 1
                self.render_value()
            event.stop()
        elif key == "delete":
            if self.cursor < len(self.value):
                self.value = self.value[: self.cursor] + self.value[self.cursor + 1 :]
                self.render_value()
            event.stop()
        elif character and character.isprintable() and character not in "\r\n\t":
            self.value = self.value[: self.cursor] + character + self.value[self.cursor :]
            self.cursor += len(character)
            self.render_value()
            event.stop()


class ValueBar(Static):
    can_focus = True

    def __init__(self, *args, **kwargs):
        super().__init__(*args, **kwargs)
        self.label = ""
        self.value = None
        self.minimum = 0.0
        self.maximum = 100.0
        self.suffix = ""
        self.width = 30
        self.step = 1.0
        self.kind = ""

    def set_value(self, label, value, minimum, maximum, suffix="", width=30, step=1, kind=""):
        self.label = label
        self.value = value
        self.minimum = float(minimum)
        self.maximum = float(maximum)
        self.suffix = suffix
        self.width = int(width)
        self.step = float(step)
        self.kind = kind
        self.render_value()

    def render_value(self):
        text = Text()
        if self.value is None:
            text.append(self.value_prefix("unknown"))
            text.append("[")
            text.append("-" * self.width, style="dim")
            text.append("]")
            self.update(text)
            return
        try:
            numeric = float(self.value)
        except (TypeError, ValueError):
            text.append(self.value_prefix("unknown"))
            text.append("[")
            text.append("-" * self.width, style="dim")
            text.append("]")
            self.update(text)
            return
        numeric = max(self.minimum, min(self.maximum, numeric))
        span = max(self.maximum - self.minimum, 1.0)
        handle = round(((numeric - self.minimum) / span) * (self.width - 1))
        handle = max(0, min(self.width - 1, handle))
        rendered = self.rendered_value()
        text.append(self.value_prefix(rendered))
        text.append("[")
        if handle:
            text.append("=" * handle, style="green")
        text.append("o", style="bold")
        if handle < self.width - 1:
            text.append("-" * ((self.width - 1) - handle), style="dim")
        text.append("]")
        self.update(text)

    def rendered_value(self):
        if self.value is None:
            return "unknown"
        try:
            numeric = float(self.value)
        except (TypeError, ValueError):
            return "unknown"
        if isinstance(self.value, float) and not numeric.is_integer():
            return f"{numeric:.1f}{self.suffix}"
        return f"{int(numeric)}{self.suffix}"

    def value_prefix(self, rendered):
        return f"{self.focus_marker()}{self.label:<10} {rendered:>8} "

    def focus_marker(self):
        return ">" if self.has_focus else " "

    def on_focus(self):
        self.render_value()

    def on_blur(self):
        self.render_value()

    def value_from_x(self, x):
        start = len(self.value_prefix(self.rendered_value())) + 1
        end = start + max(self.width - 1, 1)
        ratio = (max(start, min(end, int(x))) - start) / max(end - start, 1)
        raw = self.minimum + (ratio * (self.maximum - self.minimum))
        stepped = self.minimum + (round((raw - self.minimum) / self.step) * self.step)
        stepped = max(self.minimum, min(self.maximum, stepped))
        if self.step.is_integer():
            return int(stepped)
        return stepped

    def clamped_step(self, delta):
        current = self.value
        if current is None:
            current = (self.minimum + self.maximum) / 2
        try:
            numeric = float(current)
        except (TypeError, ValueError):
            numeric = (self.minimum + self.maximum) / 2
        next_value = numeric + delta
        next_value = max(self.minimum, min(self.maximum, next_value))
        if self.step.is_integer():
            return int(next_value)
        return next_value

    def submit_value(self, value):
        self.value = value
        self.render_value()
        app = self.app
        if hasattr(app, "request_control_value"):
            app.request_control_value(self.kind, value)

    def on_mouse_down(self, event):
        if getattr(event, "button", 0) != 1:
            return
        self.focus()
        self.submit_value(self.value_from_x(getattr(event, "x", 0)))
        event.stop()

    def on_mouse_move(self, event):
        if getattr(event, "button", 0) != 1:
            return
        self.submit_value(self.value_from_x(getattr(event, "x", 0)))
        event.stop()

    def on_key(self, event):
        if event.key in ("left", "down"):
            self.submit_value(self.clamped_step(-self.step))
            event.stop()
        elif event.key in ("right", "up"):
            self.submit_value(self.clamped_step(self.step))
            event.stop()
        elif event.key == "pagedown":
            self.submit_value(self.clamped_step(-self.step * 10))
            event.stop()
        elif event.key == "pageup":
            self.submit_value(self.clamped_step(self.step * 10))
            event.stop()
        elif event.key == "home":
            self.submit_value(int(self.minimum) if self.step.is_integer() else self.minimum)
            event.stop()
        elif event.key == "end":
            self.submit_value(int(self.maximum) if self.step.is_integer() else self.maximum)
            event.stop()


def parse_terminal_background(response):
    match = re.search(r"\x1b]11;([^\x07\x1b]+)(?:\x07|\x1b\\)", response)
    if not match:
        return None
    color = match.group(1).strip()
    if color.startswith("rgb:"):
        parts = color[4:].split("/")
    elif color.startswith("rgba:"):
        parts = color[5:].split("/")[:3]
    else:
        return None
    if len(parts) != 3:
        return None
    values = []
    for part in parts:
        if not part or not all(ch in "0123456789abcdefABCDEF" for ch in part):
            return None
        maximum = (16 ** len(part)) - 1
        if maximum <= 0:
            return None
        values.append(int(part, 16) / maximum)
    red, green, blue = values
    luminance = (0.2126 * red) + (0.7152 * green) + (0.0722 * blue)
    return "light" if luminance >= 0.5 else "dark"


def query_terminal_theme():
    if not sys.stdin.isatty() or not sys.stdout.isatty():
        return None
    fd = sys.stdin.fileno()
    try:
        original = termios.tcgetattr(fd)
    except termios.error:
        return None
    response = ""
    try:
        tty.setcbreak(fd)
        sys.stdout.write("\033]11;?\033\\")
        sys.stdout.flush()
        deadline = time.monotonic() + 0.20
        while time.monotonic() < deadline:
            readable, _, _ = select.select([fd], [], [], max(0.0, deadline - time.monotonic()))
            if not readable:
                break
            chunk = os.read(fd, 128).decode("utf-8", errors="ignore")
            response += chunk
            if "\a" in response or "\033\\" in response:
                break
    except OSError:
        return None
    finally:
        try:
            termios.tcsetattr(fd, termios.TCSADRAIN, original)
        except termios.error:
            pass
    return parse_terminal_background(response)


def macos_appearance_theme():
    try:
        result = subprocess.run(
            ["defaults", "read", "-g", "AppleInterfaceStyle"],
            text=True,
            capture_output=True,
            timeout=0.25,
        )
    except (OSError, subprocess.SubprocessError):
        return None
    if result.returncode == 0 and result.stdout.strip().lower() == "dark":
        return "dark"
    return "light"


def resolve_theme(requested):
    if requested in ("dark", "light"):
        return requested
    return query_terminal_theme() or macos_appearance_theme() or "dark"


class AmaranTui(App):
    CSS = """
    Screen {
        layout: vertical;
    }

    #status-line {
        height: 1;
        padding: 0 1;
        background: $panel;
    }

    #body {
        height: 1fr;
    }

    #fixtures-panel {
        width: 45%;
        min-width: 42;
        border: solid $primary;
    }

    #side-panel {
        width: 55%;
        min-width: 44;
    }

    #selected-panel {
        height: 15;
        border: solid $secondary;
    }

    #scenes-panel {
        height: 12;
        border: solid $accent;
    }

    #log-panel {
        height: 1fr;
        border: solid $primary-lighten-2;
    }

    .panel-title {
        text-style: bold;
        padding: 0 1;
    }

    .pad {
        padding: 0 1;
    }

    .controls-row {
        height: 3;
        padding: 0 1;
    }

    #scene-editor {
        height: 3;
        padding: 0;
    }

    #scenes {
        height: 1fr;
        padding: 0;
    }

    #scene-name {
        width: 1fr;
        height: 3;
        border: tall $surface-lighten-1;
        padding: 0;
        margin: 0 1 0 0;
    }

    #scene-name:focus {
        border: tall $accent;
    }

    #capture-scene {
        width: 14;
        min-width: 14;
        margin: 0;
    }

    Button {
        min-width: 10;
        margin: 0 1 0 0;
    }

    ValueBar {
        height: 1;
    }

    ValueBar:focus {
        background: $accent 20%;
    }

    DataTable {
        height: 1fr;
    }
    """

    BINDINGS = [
        ("q", "quit", "Quit"),
        ("r", "refresh_selected", "Refresh"),
        ("R", "refresh_all", "Refresh all"),
        ("space", "toggle_power", "On/off"),
        ("x", "toggle_capture_include", "Capture"),
        ("i", "identify", "Identify"),
        ("a", "apply_scene", "Apply scene"),
        ("c", "capture_scene", "Capture"),
        ("?", "show_help", "Help"),
    ]

    def __init__(self, root, state_path, timeout, theme_mode):
        super().__init__()
        self.theme = "textual-light" if theme_mode == "light" else "textual-dark"
        self.theme_mode = theme_mode
        self.root = Path(root).expanduser().resolve()
        self.state_path = str(Path(state_path).expanduser())
        self.timeout = str(timeout)
        self.command_timeout = self._command_timeout(timeout)
        self.status_timeout = self._status_timeout()
        self.fixtures: Dict[int, FixtureView] = {}
        self.fixture_order: List[int] = []
        self.selected_address: Optional[int] = None
        self.capture_include = set()
        self.scenes: List[SceneView] = []
        self.scene_order: List[str] = []
        self.selected_scene_index = 0
        self.refresh_all_task = None
        self.control_generations = {}
        self.control_workers = {}
        self.control_active = {}
        self.control_sending = set()
        self.control_debounce_seconds = self._control_debounce_seconds()

    def compose(self) -> ComposeResult:
        yield Header(show_clock=True)
        yield Static("daemon: unknown    mesh: unknown    last refresh: never", id="status-line")
        with Horizontal(id="body"):
            with Vertical(id="fixtures-panel"):
                yield Static("Fixtures", classes="panel-title")
                yield DataTable(id="fixtures")
            with Vertical(id="side-panel"):
                with Vertical(id="selected-panel"):
                    yield Static("Selected", id="selected-title", classes="panel-title")
                    yield ValueBar(id="brightness", classes="pad")
                    yield ValueBar(id="cct", classes="pad")
                    yield ValueBar(id="gm", classes="pad")
                    with Horizontal(classes="controls-row"):
                        yield Button("On", id="power-on", variant="success")
                        yield Button("Off", id="power-off", variant="error")
                        yield Button("Refresh", id="refresh-selected")
                        yield Button("Identify", id="identify")
                    with Horizontal(classes="controls-row"):
                        yield Button("Capture", id="capture-include")
                with Vertical(id="scenes-panel"):
                    yield Static("Scenes", classes="panel-title")
                    yield SceneList(id="scenes")
                    with Horizontal(id="scene-editor"):
                        yield SceneNameField(id="scene-name")
                        yield Button("Save Scene", id="capture-scene")
                with Vertical(id="log-panel"):
                    yield Static("Log", classes="panel-title")
                    yield Log(id="log")
        yield Footer()

    async def on_mount(self):
        fixtures = self.query_one("#fixtures", DataTable)
        fixtures.cursor_type = "row"
        fixtures.zebra_stripes = True
        fixtures.add_columns("fixture", "addr", "cap", "state", "power", "int", "cct", "gm")

        await self.load_initial()
        fixtures.focus()

    async def load_initial(self):
        await self.refresh_daemon()
        await self.load_fixtures()
        await self.load_scenes()
        self.update_selected_panel()

    @staticmethod
    def _command_timeout(value):
        try:
            return max(1.0, float(value))
        except ValueError:
            return 20.0

    def _status_timeout(self):
        configured = os.environ.get("AMARAN_TUI_STATUS_TIMEOUT")
        if configured:
            return self._command_timeout(configured)
        return min(self.command_timeout, 5.0)

    def _control_debounce_seconds(self):
        configured = os.environ.get("AMARAN_TUI_DEBOUNCE")
        if configured:
            try:
                return max(0.05, float(configured))
            except ValueError:
                return 0.35
        return 0.35

    def append_log(self, message):
        timestamp = datetime.now().strftime("%H:%M:%S")
        self.query_one("#log", Log).write_line(f"{timestamp} {message}")

    async def run_amaran(self, *args, expect_json=False, extra_timeout=5.0, cli_timeout=None, wait_timeout=None):
        timeout_value = str(cli_timeout if cli_timeout is not None else self.timeout)
        command = [
            str(self.root / "bin" / "amaran"),
            *[str(arg) for arg in args],
            "--state-path",
            self.state_path,
            "--timeout",
            timeout_value,
        ]
        process = await asyncio.create_subprocess_exec(
            *command,
            stdout=asyncio.subprocess.PIPE,
            stderr=asyncio.subprocess.PIPE,
            cwd=str(self.root),
        )
        try:
            limit = wait_timeout if wait_timeout is not None else self._command_timeout(timeout_value) + extra_timeout
            stdout_b, stderr_b = await asyncio.wait_for(
                process.communicate(),
                timeout=limit,
            )
        except asyncio.TimeoutError:
            process.kill()
            await process.communicate()
            raise CommandError(command, f"command timed out after {limit:g}s")

        stdout = stdout_b.decode("utf-8", errors="replace")
        stderr = stderr_b.decode("utf-8", errors="replace")
        if process.returncode != 0:
            detail = (stderr or stdout).strip().splitlines()[-1:] or [f"exit {process.returncode}"]
            raise CommandError(command, detail[0])
        if expect_json:
            try:
                return json.loads(stdout)
            except json.JSONDecodeError as exc:
                raise CommandError(command, f"invalid JSON: line {exc.lineno} column {exc.colno}")
        return stdout.strip()

    async def refresh_daemon(self):
        try:
            payload = await self.run_amaran("daemon", "status", "--json", expect_json=True)
            data = payload.get("data") or {}
            daemon = data.get("daemon") or {}
            state = data.get("central_state", "unknown")
            connected = "yes" if data.get("connected") else "no"
            self.query_one("#status-line", Static).update(
                f"daemon: running pid {daemon.get('pid', '?')}    bluetooth: {state}    connected: {connected}    theme: {self.theme_mode}"
            )
        except CommandError as exc:
            self.query_one("#status-line", Static).update(
                f"daemon: unavailable    theme: {self.theme_mode}    {exc.message}"
            )

    async def load_fixtures(self):
        try:
            rows = await self.run_amaran("list", "--json", expect_json=True)
        except CommandError as exc:
            self.append_log(f"fixture load failed: {exc.message}")
            return

        previous = self.fixtures
        previous_include = set(self.capture_include)
        self.fixtures = {}
        self.fixture_order = []
        for row in rows if isinstance(rows, list) else []:
            if not isinstance(row, dict):
                continue
            try:
                address = int(row.get("address"))
            except (TypeError, ValueError):
                continue
            prior = previous.get(address)
            fixture = FixtureView(
                name=str(row.get("name") or f"fixture-{address}"),
                friendly_name=row.get("friendly_name"),
                source_name=row.get("source_name"),
                address=address,
                mac=row.get("mac"),
            )
            if prior:
                fixture.status = prior.status
                fixture.power = prior.power
                fixture.intensity = prior.intensity
                fixture.cct = prior.cct
                fixture.gm = prior.gm
                fixture.last_error = prior.last_error
                fixture.pending = prior.pending
                fixture.updated_at = prior.updated_at
            self.fixtures[address] = fixture
            self.fixture_order.append(address)
        if self.selected_address not in self.fixtures:
            self.selected_address = self.fixture_order[0] if self.fixture_order else None
        current_addresses = set(self.fixture_order)
        self.capture_include = previous_include & current_addresses
        self.render_fixtures()
        self.append_log(f"loaded {len(self.fixture_order)} fixtures")

    async def load_scenes(self):
        try:
            payload = await self.run_amaran("scene", "list", "--json", expect_json=True)
        except CommandError as exc:
            self.append_log(f"scene load failed: {exc.message}")
            return
        self.scenes = []
        self.scene_order = []
        for row in payload.get("scenes", []) if isinstance(payload, dict) else []:
            if not isinstance(row, dict):
                continue
            name = row.get("name")
            if not name:
                continue
            scene = SceneView(
                name=str(name),
                fixture_count=int(row.get("fixture_count") or 0),
                captured_at=row.get("captured_at"),
            )
            self.scenes.append(scene)
            self.scene_order.append(scene.name)
        self.render_scenes()
        self.append_log(f"loaded {len(self.scenes)} scenes")

    def render_fixtures(self):
        table = self.query_one("#fixtures", DataTable)
        selected_address = self.selected_address
        table.clear()
        for address in self.fixture_order:
            fixture = self.fixtures[address]
            table.add_row(
                fixture.name,
                str(address),
                "[x]" if address in self.capture_include else "[ ]",
                self.render_status(fixture),
                fixture.power,
                self.render_percent(fixture.intensity),
                f"{fixture.cct}K" if fixture.cct is not None else "?",
                str(fixture.gm) if fixture.gm is not None else "?",
                key=str(address),
            )
        if selected_address in self.fixtures and selected_address in self.fixture_order:
            table.move_cursor(row=self.fixture_order.index(selected_address), column=0, animate=False, scroll=False)

    def render_scenes(self):
        table = self.query_one("#scenes", SceneList)
        table.set_scenes(self.scenes, self.selected_scene_index)
        self.selected_scene_index = table.selected_index

    @staticmethod
    def render_status(fixture):
        if fixture.pending:
            return "pending"
        if fixture.status == "error":
            return "error"
        return fixture.status

    @staticmethod
    def render_percent(value):
        if value is None:
            return "?"
        if isinstance(value, float) and not value.is_integer():
            return f"{value:.1f}%"
        return f"{int(value)}%"

    def current_fixture(self):
        if self.selected_address in self.fixtures:
            return self.fixtures[self.selected_address]
        if not self.fixture_order:
            self.selected_address = None
            return None
        table = self.query_one("#fixtures", DataTable)
        row = max(0, min(table.cursor_row, len(self.fixture_order) - 1))
        self.selected_address = self.fixture_order[row]
        return self.fixtures.get(self.selected_address)

    def update_selected_fixture_from_table(self, event=None):
        if event is not None:
            row_key = getattr(event, "row_key", None)
            value = getattr(row_key, "value", None)
            try:
                address = int(value)
            except (TypeError, ValueError):
                address = None
            if address in self.fixtures:
                self.selected_address = address
                return
        if not self.fixture_order:
            self.selected_address = None
            return
        table = self.query_one("#fixtures", DataTable)
        row = max(0, min(table.cursor_row, len(self.fixture_order) - 1))
        self.selected_address = self.fixture_order[row]

    def current_scene(self):
        table = self.query_one("#scenes", SceneList)
        self.selected_scene_index = table.selected_index
        return table.selected_scene()

    def update_selected_panel(self):
        fixture = self.current_fixture()
        title = self.query_one("#selected-title", Static)
        brightness = self.query_one("#brightness", ValueBar)
        cct = self.query_one("#cct", ValueBar)
        gm = self.query_one("#gm", ValueBar)
        if fixture is None:
            title.update("Selected")
            brightness.set_value("Brightness", None, 0, 100, "%", step=1, kind="brightness")
            cct.set_value("Temp", None, 2000, 10000, "K", step=100, kind="cct")
            gm.set_value("G/M", None, 0, 20, step=1, kind="gm")
            return
        detail = f"{fixture.name}  addr {fixture.address}  {fixture.status}"
        if fixture.last_error:
            detail += f"  error: {fixture.last_error}"
        title.update(detail)
        brightness.set_value("Brightness", fixture.intensity, 0, 100, "%", step=1, kind="brightness")
        cct.set_value("Temp", fixture.cct, 2000, 10000, "K", step=100, kind="cct")
        gm.set_value("G/M", fixture.gm, 0, 20, step=1, kind="gm")

    async def refresh_fixture(self, fixture):
        fixture.pending = True
        fixture.last_error = None
        self.render_fixtures()
        self.update_selected_panel()
        try:
            payload = await self.run_amaran(
                "status",
                "--json",
                "--node",
                fixture.selector,
                expect_json=True,
                cli_timeout=f"{self.status_timeout:g}",
                wait_timeout=self.status_timeout + 2,
            )
            cct = payload.get("cct") or {}
            fixture.status = "online"
            fixture.power = "off" if cct.get("sleep_mode") == 0 else "on"
            intensity = cct.get("intensity_percent")
            if intensity is None and isinstance(cct.get("intensity"), (int, float)):
                intensity = float(cct["intensity"]) / 10.0
            fixture.intensity = float(intensity) if intensity is not None else None
            fixture.cct = int(cct["cct"]) if cct.get("cct") is not None else fixture.cct
            fixture.gm = int(cct["gm"]) if cct.get("gm") is not None else fixture.gm
            fixture.updated_at = datetime.now()
            self.append_log(f"status {fixture.name}: {fixture.power}, {self.render_percent(fixture.intensity)}, {fixture.cct or '?'}K, gm {fixture.gm if fixture.gm is not None else '?'}")
        except CommandError as exc:
            fixture.status = "error"
            fixture.power = "unknown"
            fixture.last_error = exc.message
            self.append_log(f"status {fixture.name} failed: {exc.message}")
        finally:
            fixture.pending = False
            self.render_fixtures()
            self.update_selected_panel()

    async def control_fixture(self, fixture, command, *args):
        if command in ("on", "off"):
            self.cancel_control_send(fixture.address)
        fixture.pending = True
        fixture.last_error = None
        self.render_fixtures()
        self.update_selected_panel()
        try:
            await self.run_amaran(command, *args, "--node", fixture.selector)
            if command == "on":
                fixture.power = "on"
                fixture.status = "online"
            elif command == "off":
                fixture.power = "off"
                fixture.status = "online"
            elif command == "intensity":
                fixture.intensity = float(args[0])
                fixture.power = "on"
                fixture.status = "online"
            elif command == "cct":
                fixture.cct = int(args[0])
                if "--intensity" in args:
                    index = args.index("--intensity")
                    fixture.intensity = float(args[index + 1])
                if "--gm" in args:
                    index = args.index("--gm")
                    fixture.gm = int(args[index + 1])
                fixture.power = "on"
                fixture.status = "online"
            elif command == "gm":
                fixture.gm = int(args[0])
                fixture.power = "on"
                fixture.status = "online"
            fixture.updated_at = datetime.now()
            rendered = " ".join([command, *[str(arg) for arg in args]]).strip()
            self.append_log(f"sent {fixture.name}: {rendered}")
        except CommandError as exc:
            fixture.status = "error"
            fixture.last_error = exc.message
            self.append_log(f"control {fixture.name} failed: {exc.message}")
        finally:
            fixture.pending = False
            self.render_fixtures()
            self.update_selected_panel()

    async def set_cct_bundle(self, fixture, cct=None, intensity=None, gm=None):
        next_cct = int(cct if cct is not None else fixture.cct if fixture.cct is not None else 5600)
        next_intensity = float(
            intensity if intensity is not None else fixture.intensity if fixture.intensity is not None else 50
        )
        next_gm = int(gm if gm is not None else fixture.gm if fixture.gm is not None else 10)
        next_cct = max(2000, min(10000, next_cct))
        next_intensity = max(0, min(100, next_intensity))
        next_gm = max(0, min(20, next_gm))
        await self.control_fixture(
            fixture,
            "cct",
            str(next_cct),
            "--intensity",
            f"{next_intensity:g}",
            "--gm",
            str(next_gm),
        )

    def request_control_value(self, kind, value):
        fixture = self.current_fixture()
        if not fixture:
            return
        if kind == "brightness":
            fixture.intensity = max(0, min(100, float(value)))
        elif kind == "cct":
            fixture.cct = max(2000, min(10000, int(value)))
        elif kind == "gm":
            fixture.gm = max(0, min(20, int(value)))
        else:
            return
        fixture.power = "on"
        fixture.status = "online"
        fixture.last_error = None
        fixture.updated_at = datetime.now()
        self.render_fixtures()
        self.update_selected_panel()
        self.queue_control_send(fixture.address)

    def queue_control_send(self, address):
        generation = int(self.control_generations.get(address, 0)) + 1
        self.control_generations[address] = generation
        self.control_active[address] = True
        worker = self.control_workers.get(address)
        if worker is None or worker.done():
            self.control_workers[address] = asyncio.create_task(self.control_send_worker(address))

    def cancel_control_send(self, address):
        self.control_active[address] = False
        self.control_generations[address] = int(self.control_generations.get(address, 0)) + 1

    def cancel_all_control_sends(self):
        for address in list(self.control_active):
            self.cancel_control_send(address)

    async def flush_control_sends(self):
        addresses = [address for address, active in self.control_active.items() if active]
        for address in addresses:
            worker = self.control_workers.get(address)
            if address in self.control_sending and worker is not None:
                await worker
                continue
            self.cancel_control_send(address)
            fixture = self.fixtures.get(address)
            if fixture:
                await self.set_cct_bundle(fixture)

    async def control_send_worker(self, address):
        try:
            while True:
                if not self.control_active.get(address, False):
                    return
                generation = self.control_generations.get(address, 0)
                await asyncio.sleep(self.control_debounce_seconds)
                if not self.control_active.get(address, False):
                    return
                if self.control_generations.get(address, 0) != generation:
                    continue
                fixture = self.fixtures.get(address)
                if not fixture:
                    return
                self.control_sending.add(address)
                try:
                    await self.set_cct_bundle(fixture)
                finally:
                    self.control_sending.discard(address)
                if self.control_generations.get(address, 0) == generation:
                    self.control_active[address] = False
                    return
        finally:
            current = asyncio.current_task()
            if self.control_workers.get(address) is current:
                self.control_workers.pop(address, None)

    def schedule(self, coro):
        asyncio.create_task(coro)

    async def action_refresh_selected(self):
        fixture = self.current_fixture()
        if fixture:
            await self.refresh_fixture(fixture)

    def action_refresh_all(self):
        if self.refresh_all_task and not self.refresh_all_task.done():
            self.append_log("refresh all already running")
            return
        self.refresh_all_task = asyncio.create_task(self.refresh_all())

    async def refresh_all(self):
        try:
            addresses = list(self.fixture_order)
            total = len(addresses)
            self.append_log(f"refreshing all fixtures with {self.status_timeout:g}s status timeout")
            for index, address in enumerate(addresses, start=1):
                fixture = self.fixtures.get(address)
                if fixture:
                    self.append_log(f"refresh {index}/{total}: {fixture.name}")
                    await self.refresh_fixture(fixture)
            self.append_log("refresh all complete")
        finally:
            self.refresh_all_task = None

    async def action_toggle_power(self):
        fixture = self.current_fixture()
        if not fixture:
            return
        if fixture.power == "on":
            await self.control_fixture(fixture, "off")
        else:
            await self.control_fixture(fixture, "on")

    async def action_identify(self):
        fixture = self.current_fixture()
        if not fixture:
            return
        fixture.pending = True
        self.render_fixtures()
        try:
            await self.run_amaran("identify", "--node", fixture.selector, extra_timeout=self.command_timeout + 10)
            self.append_log(f"identified {fixture.name}")
        except CommandError as exc:
            fixture.status = "error"
            fixture.last_error = exc.message
            self.append_log(f"identify {fixture.name} failed: {exc.message}")
        finally:
            fixture.pending = False
            self.render_fixtures()
            self.update_selected_panel()

    async def action_apply_scene(self):
        scene = self.current_scene()
        if not scene:
            self.append_log("no scene selected")
            return
        self.cancel_all_control_sends()
        self.append_log(f"applying scene {scene}")
        try:
            await self.run_amaran("scene", "apply", scene, extra_timeout=self.command_timeout * 2)
            self.append_log(f"applied scene {scene}")
            for fixture in self.fixtures.values():
                fixture.status = "unknown"
                fixture.power = "unknown"
            self.render_fixtures()
            self.update_selected_panel()
        except CommandError as exc:
            self.append_log(f"scene apply failed: {exc.message}")

    async def action_capture_scene(self):
        await self.capture_scene()

    def action_toggle_capture_include(self):
        fixture = self.current_fixture()
        if not fixture:
            return
        address = fixture.address
        if address in self.capture_include:
            self.capture_include.discard(address)
            self.append_log(f"excluded {fixture.name} from scene capture")
        else:
            self.capture_include.add(address)
            self.append_log(f"included {fixture.name} in scene capture")
        self.render_fixtures()
        self.update_selected_panel()

    def action_show_help(self):
        self.append_log("keys: q quit, r/R refresh, space on/off, x capture, +/- brightness, [] temp, g/m G/M, arrows on focused sliders, a apply scene, c save scene, i identify")

    async def adjust_brightness(self, delta):
        fixture = self.current_fixture()
        if not fixture:
            return
        current = fixture.intensity if fixture.intensity is not None else 50
        self.request_control_value("brightness", current + delta)

    async def adjust_cct(self, delta):
        fixture = self.current_fixture()
        if not fixture:
            return
        current = fixture.cct if fixture.cct is not None else 5600
        self.request_control_value("cct", current + delta)

    async def adjust_gm(self, delta):
        fixture = self.current_fixture()
        if not fixture:
            return
        current = fixture.gm if fixture.gm is not None else 10
        self.request_control_value("gm", current + delta)

    async def capture_scene(self):
        fixture = self.current_fixture()
        if not fixture:
            self.append_log("no fixture selected")
            return
        name = self.query_one("#scene-name", SceneNameField).value.strip()
        if not name:
            self.append_log("enter a scene name before capture")
            return
        included = [address for address in self.fixture_order if address in self.capture_include]
        if not included:
            self.append_log("select fixtures for capture with x; included fixtures marked off are saved as off")
            return
        await self.flush_control_sends()
        command = ["scene", "capture", name]
        live_count = 0
        off_count = 0
        for address in included:
            target = self.fixtures.get(address)
            if not target:
                continue
            if target.power == "off":
                command.extend(["--off-node", target.selector])
                off_count += 1
            else:
                command.extend(["--node", target.selector])
                live_count += 1
        try:
            await self.run_amaran(*command, extra_timeout=self.command_timeout * 2)
            self.append_log(f"captured {name}: {live_count} live, {off_count} off")
            await self.load_scenes()
        except CommandError as exc:
            self.append_log(f"scene capture failed: {exc.message}")

    @on(DataTable.RowHighlighted, "#fixtures")
    def fixture_highlighted(self, event):
        self.update_selected_fixture_from_table(event)
        self.update_selected_panel()

    @on(DataTable.RowSelected, "#fixtures")
    def fixture_selected(self, event):
        self.update_selected_fixture_from_table(event)
        self.update_selected_panel()

    @on(Button.Pressed, "#refresh-selected")
    def refresh_button(self, _event):
        self.schedule(self.action_refresh_selected())

    @on(Button.Pressed, "#power-on")
    def on_button(self, _event):
        fixture = self.current_fixture()
        if fixture:
            self.schedule(self.control_fixture(fixture, "on"))

    @on(Button.Pressed, "#power-off")
    def off_button(self, _event):
        fixture = self.current_fixture()
        if fixture:
            self.schedule(self.control_fixture(fixture, "off"))

    @on(Button.Pressed, "#identify")
    def identify_button(self, _event):
        self.schedule(self.action_identify())

    @on(Button.Pressed, "#capture-include")
    def capture_include_button(self, _event):
        self.action_toggle_capture_include()

    @on(Button.Pressed, "#capture-scene")
    def capture_scene_button(self, _event):
        self.schedule(self.capture_scene())

    async def on_key(self, event):
        if isinstance(self.focused, SceneNameField):
            return
        char = event.character
        if char in ("+", "="):
            event.stop()
            await self.adjust_brightness(1)
        elif char == "-":
            event.stop()
            await self.adjust_brightness(-1)
        elif char == "]":
            event.stop()
            await self.adjust_cct(100)
        elif char == "[":
            event.stop()
            await self.adjust_cct(-100)
        elif char == "}":
            event.stop()
            await self.adjust_cct(500)
        elif char == "{":
            event.stop()
            await self.adjust_cct(-500)
        elif char == "m":
            event.stop()
            await self.adjust_gm(1)
        elif char == "g":
            event.stop()
            await self.adjust_gm(-1)


def main():
    args = build_parser().parse_args()
    app = AmaranTui(args.root, args.state_path, args.timeout, resolve_theme(args.theme))
    app.run()


if __name__ == "__main__":
    main()
