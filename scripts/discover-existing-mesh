#!/usr/bin/env python3
import argparse
import json
import os
import signal
import subprocess
import sys
import tempfile
from datetime import datetime, timezone
from pathlib import Path


def fail(message):
    print(f"amaran: {message}", file=sys.stderr)
    raise SystemExit(1)


def now_iso():
    return datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def parse_range(spec):
    if not spec:
        fail("discover requires --range <start-end>")
    addresses = []
    try:
        for part in spec.split(","):
            part = part.strip()
            if not part:
                continue
            if "-" in part:
                start_text, end_text = part.split("-", 1)
                start = int(start_text, 0)
                end = int(end_text, 0)
                if start > end:
                    fail("discover has invalid --range")
                addresses.extend(range(start, end + 1))
            else:
                addresses.append(int(part, 0))
    except ValueError:
        fail("discover has invalid --range")
    if not addresses:
        fail("discover has invalid --range")
    unique = []
    seen = set()
    for address in addresses:
        if not 1 <= address <= 0x7FFF:
            fail("discover --range contains a non-unicast address")
        if address not in seen:
            unique.append(address)
            seen.add(address)
    return unique


def load_state(path):
    try:
        with open(path, "r", encoding="utf-8") as handle:
            payload = json.load(handle)
    except FileNotFoundError:
        fail(f"local state not found at {path}")
    except json.JSONDecodeError as exc:
        fail(f"local state could not be read: invalid JSON at line {exc.lineno} column {exc.colno}")
    if not isinstance(payload, dict) or payload.get("schema_version") != 1:
        fail("local state has unsupported schema")
    if not isinstance(payload.get("mesh"), dict) or not isinstance(payload.get("fixtures"), list):
        fail("local state is missing mesh or fixture data")
    return payload


def write_state(path, payload):
    target = Path(path)
    fd, tmp = tempfile.mkstemp(prefix=".discover-existing-mesh.", suffix=".json", dir=str(target.parent))
    try:
        os.fchmod(fd, 0o600)
        with os.fdopen(fd, "w", encoding="utf-8") as handle:
            json.dump(payload, handle, indent=2, sort_keys=True)
            handle.write("\n")
            handle.flush()
            os.fsync(handle.fileno())
        os.replace(tmp, target)
        os.chmod(target, 0o600)
    except Exception:
        try:
            os.unlink(tmp)
        except OSError:
            pass
        raise


def int_in_range(value, minimum, maximum):
    try:
        parsed = int(value)
    except (TypeError, ValueError):
        return None
    if minimum <= parsed <= maximum:
        return parsed
    return None


def occupied_addresses(payload):
    occupied = set()
    for fixture in payload.get("fixtures", []):
        if not isinstance(fixture, dict):
            continue
        address = int_in_range(fixture.get("node_address"), 1, 0x7FFF)
        if address is None:
            continue
        element_count = int_in_range(fixture.get("element_count", 1), 1, 255) or 1
        for offset in range(element_count):
            element_address = address + offset
            if 1 <= element_address <= 0x7FFF:
                occupied.add(element_address)
    return occupied


def choose_source_address(payload, avoid):
    runtime = payload.get("runtime") if isinstance(payload.get("runtime"), dict) else {}
    occupied = occupied_addresses(payload)
    telink_source = int_in_range(runtime.get("telink_source_address"), 1, 0x7FFF)
    blocked = set(occupied) | set(avoid)
    if telink_source is not None:
        blocked.add(telink_source)
    for candidate in range(3, 0x8000):
        if candidate not in blocked:
            return candidate
    for candidate in range(2, 0x8000):
        if candidate not in blocked:
            return candidate
    fail("discover could not choose a safe CLI source address")


def relocate_runtime_source_if_needed(payload, scan_addresses):
    runtime = payload.get("runtime")
    if not isinstance(runtime, dict):
        return None
    source = int_in_range(runtime.get("source_address"), 1, 0x7FFF)
    if source is None or source not in set(scan_addresses):
        return None
    replacement = choose_source_address(payload, set(scan_addresses))
    runtime["source_address"] = replacement
    runtime["updated_at"] = now_iso()
    runtime["last_reserved_by"] = "discover-source-relocation"
    return {"from": source, "to": replacement}


def mac_suffix(value):
    return "".join(ch for ch in str(value or "") if ch in "0123456789abcdefABCDEF").upper()[-6:]


def fixture_label(fixture):
    if fixture.get("friendly_name"):
        return str(fixture["friendly_name"])
    if fixture.get("name"):
        return str(fixture["name"])
    suffix = mac_suffix(fixture.get("mac_address"))
    code = fixture.get("code")
    if code and suffix:
        return f"{code}-{suffix}"
    return suffix or f"fixture-{fixture.get('node_address', 'unknown')}"


def ensure_fixture(payload, address):
    for fixture in payload["fixtures"]:
        if isinstance(fixture, dict) and fixture.get("node_address") == address:
            return False
    payload["fixtures"].append({
        "uuid": f"discovered-{address}",
        "mac_address": "",
        "code": "",
        "name": f"fixture-{address}",
        "node_address": address,
        "composition_data": "",
        "element_count": 1,
        "update_time": now_iso(),
        "state": 0,
        "control_only": True,
    })
    return True


def remove_fixture(payload, address):
    payload["fixtures"] = [
        fixture for fixture in payload.get("fixtures", [])
        if not (isinstance(fixture, dict) and fixture.get("node_address") == address)
    ]


def find_fixture(payload, address):
    return next(
        (item for item in payload.get("fixtures", []) if isinstance(item, dict) and item.get("node_address") == address),
        None,
    )


def status_for(root, state_path, timeout, address):
    command = [
        str(Path(root) / "bin" / "amaran"),
        "status",
        "--json",
        "--node",
        str(address),
        "--state-path",
        str(state_path),
        "--timeout",
        str(timeout),
    ]
    return subprocess.run(command, text=True, capture_output=True)


def status_batch_for(root, state_path, timeout, addresses):
    app = Path(root) / "BluetoothProbe.app"
    if not app.exists():
        return None

    fd, output = tempfile.mkstemp(prefix="amaran-discover-batch.", suffix=".json")
    os.close(fd)
    try:
        try:
            timeout_number = max(1.0, float(timeout))
        except (TypeError, ValueError):
            timeout_number = 20.0
        settle = min(max(2.0, 1.5 + (len(addresses) * 0.02)), max(0.5, timeout_number - 2.0))
        command = [
            "/usr/bin/open",
            "-n",
            "-W",
            str(app),
            "--args",
            "--output",
            output,
            "--timeout",
            str(timeout),
            "--state-path",
            str(state_path),
            "--status-batch",
            ",".join(str(address) for address in addresses),
            "--settle-after-write",
            f"{settle:g}",
        ]
        result = subprocess.run(command, text=True, capture_output=True)
        try:
            with open(output, "r", encoding="utf-8") as handle:
                payload = json.load(handle)
        except (FileNotFoundError, json.JSONDecodeError):
            detail = (result.stderr or result.stdout or "").strip().splitlines()[-1:] or ["status batch did not write a result"]
            fail(detail[0])
        if not payload.get("ok"):
            fail(payload.get("error") or "status batch failed")
        return payload.get("data") or {}
    finally:
        try:
            os.unlink(output)
        except OSError:
            pass


def normalize_status(address, fixture, raw_status):
    cct = raw_status.get("cct") or {}
    intensity = cct.get("intensity_percent")
    if intensity is None:
        raw_intensity = cct.get("intensity")
        if isinstance(raw_intensity, (int, float)):
            intensity = raw_intensity / 10
    cct_kelvin = cct.get("cct_kelvin", cct.get("cct"))
    if isinstance(cct_kelvin, (int, float)) and cct_kelvin < 1000:
        cct_kelvin = cct_kelvin * 10
    return {
        "address": address,
        "name": fixture_label(fixture),
        "mac_suffix": mac_suffix(fixture.get("mac_address")),
        "intensity": intensity,
        "cct": cct_kelvin,
        "gm": cct.get("gm_decoded", cct.get("gm")),
        "sleep_mode": cct.get("sleep_mode"),
        "control_only": bool(fixture.get("control_only")),
    }


def progress(args, message):
    stream = sys.stderr if args.json else sys.stdout
    print(message, file=stream, flush=True)


def status_detail(fixture):
    details = []
    if fixture.get("intensity") is not None:
        details.append(f"{fixture['intensity']:g}%")
    if fixture.get("cct") is not None:
        details.append(f"{fixture['cct']}K")
    if fixture.get("gm") is not None:
        details.append(f"gm={fixture['gm']}")
    if fixture.get("sleep_mode") is not None:
        details.append(f"sleep={fixture['sleep_mode']}")
    return ", ".join(details)


def status_notifications_by_source(batch_data, addresses):
    wanted = set(addresses)
    statuses = {}
    for notification in batch_data.get("proxy_notifications") or []:
        if not isinstance(notification, dict):
            continue
        network = notification.get("network") or {}
        source = network.get("source")
        if source not in wanted:
            continue
        telink = ((notification.get("access") or {}).get("telink") or {})
        cct = telink.get("cct")
        if not isinstance(cct, dict):
            continue
        statuses[source] = {
            "cct": cct,
        }
    return statuses


def format_percent(value):
    if value is None:
        return "-"
    if isinstance(value, (int, float)):
        return f"{value:g}%"
    return f"{value}%"


def format_kelvin(value):
    if value is None:
        return "-"
    return f"{value}K"


def format_gm(value):
    if value is None:
        return "-"
    return str(value)


def print_fixture_table(fixtures):
    if not fixtures:
        return

    rows = []
    for fixture in fixtures:
        suffix = fixture.get("mac_suffix") or "unknown"
        rows.append({
            "name": str(fixture["name"]),
            "addr": str(fixture["address"]),
            "mac": f"...{suffix}",
            "intensity": format_percent(fixture.get("intensity")),
            "cct": format_kelvin(fixture.get("cct")),
            "gm": format_gm(fixture.get("gm")),
        })

    headers = {
        "name": "name",
        "addr": "addr",
        "mac": "mac",
        "intensity": "intensity",
        "cct": "cct",
        "gm": "gm",
    }
    columns = [
        ("name", "<"),
        ("addr", ">"),
        ("mac", ">"),
        ("intensity", ">"),
        ("cct", ">"),
        ("gm", ">"),
    ]
    widths = {
        key: max(len(headers[key]), *(len(row[key]) for row in rows))
        for key, _align in columns
    }

    print("  ".join(f"{headers[key]:<{widths[key]}}" for key, _align in columns))
    for row in rows:
        cells = []
        for key, align in columns:
            if align == ">":
                cells.append(f"{row[key]:>{widths[key]}}")
            else:
                cells.append(f"{row[key]:<{widths[key]}}")
        print("  ".join(cells))


def print_discover_output(args, found, misses, source_relocation):
    output = {
        "discovered": len(found),
        "range": args.range,
        "updated_state": bool(args.update_state),
        "fixtures": found,
        "misses": misses,
    }
    if source_relocation:
        output["runtime_source_relocated"] = source_relocation
    if args.json:
        print(json.dumps(output, indent=2))
        return

    print(f"discovered {len(found)} fixtures in range {args.range}")
    print_fixture_table(found)
    if source_relocation:
        print(f"runtime source moved {source_relocation['from']}->{source_relocation['to']} to avoid scanned fixture addresses")
    if not args.update_state:
        print("state fixtures unchanged; sequence counters may be advanced")


def install_interrupt_handler():
    def handle_signal(_signum, _frame):
        raise KeyboardInterrupt

    signal.signal(signal.SIGTERM, handle_signal)


def main():
    install_interrupt_handler()
    parser = argparse.ArgumentParser(description="Discover control-capable fixtures already on a known mesh")
    parser.add_argument("--root", required=True)
    parser.add_argument("--state-path", required=True)
    parser.add_argument("--timeout", default="20")
    parser.add_argument("--range", required=True)
    parser.add_argument("--update-state", action="store_true")
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args()

    state_path = Path(args.state_path).expanduser().resolve()
    addresses = parse_range(args.range)
    payload = load_state(state_path)
    source_relocation = relocate_runtime_source_if_needed(payload, addresses)
    if source_relocation:
        write_state(state_path, payload)
        progress(args, f"discover moved runtime source {source_relocation['from']}->{source_relocation['to']} before scanning")
    runtime = payload.get("runtime") or {}
    reserved = {runtime.get("telink_source_address")}

    total = len(addresses)
    mode = "updating state" if args.update_state else "probing without adding fixtures"
    progress(args, f"discover scanning {total} address{'es' if total != 1 else ''} in range {args.range} ({mode})")

    found = []
    misses = []
    batch_data = status_batch_for(args.root, state_path, args.timeout, addresses)
    if batch_data is not None:
        proxy_write = batch_data.get("proxy_write") or {}
        progress(
            args,
            "discover batch sent "
            f"{proxy_write.get('logical_pdu_count', len(addresses))} probes "
            f"over one Mesh Proxy connection"
        )
        statuses = status_notifications_by_source(batch_data, addresses)
        latest = load_state(state_path)
        for index, address in enumerate(addresses, start=1):
            step = f"[{index}/{total}]"
            fixture = find_fixture(latest, address) or {
                "node_address": address,
                "name": f"fixture-{address}",
                "control_only": True,
            }
            raw_status = statuses.get(address)
            if raw_status:
                status = normalize_status(address, fixture, raw_status)
                found.append(status)
                detail = status_detail(status)
                detail_suffix = f": {detail}" if detail else ""
                progress(args, f"{step} found address {address}: {status['name']}{detail_suffix}")
            else:
                misses.append({"address": address, "reason": "no-status"})
                progress(args, f"{step} no response at address {address}")

        if args.update_state and found:
            latest = load_state(state_path)
            for fixture in found:
                ensure_fixture(latest, fixture["address"])
            write_state(state_path, latest)

        print_discover_output(args, found, misses, source_relocation)
        return

    active_temporary_address = None
    try:
        for index, address in enumerate(addresses, start=1):
            step = f"[{index}/{total}]"
            if address in reserved:
                misses.append({"address": address, "reason": "reserved-source-address"})
                progress(args, f"{step} skip address {address}: reserved Telink source address")
                continue

            payload = load_state(state_path)
            fixture_before = find_fixture(payload, address)
            label = f" ({fixture_label(fixture_before)})" if fixture_before else ""
            progress(args, f"{step} probing address {address}{label}")

            added = ensure_fixture(payload, address)
            if added:
                active_temporary_address = address
            write_state(state_path, payload)

            result = status_for(args.root, state_path, args.timeout, address)
            latest = load_state(state_path)
            fixture = find_fixture(latest, address) or {"node_address": address, "name": f"fixture-{address}"}
            if result.returncode == 0:
                try:
                    raw_status = json.loads(result.stdout)
                except json.JSONDecodeError:
                    raw_status = {}
                status = normalize_status(address, fixture, raw_status)
                found.append(status)
                detail = status_detail(status)
                detail_suffix = f": {detail}" if detail else ""
                progress(args, f"{step} found address {address}: {status['name']}{detail_suffix}")
                if added and not args.update_state:
                    remove_fixture(latest, address)
                    write_state(state_path, latest)
                active_temporary_address = None
            else:
                misses.append({"address": address, "reason": "no-status"})
                progress(args, f"{step} no response at address {address}")
                if added:
                    remove_fixture(latest, address)
                    write_state(state_path, latest)
                active_temporary_address = None
    except KeyboardInterrupt:
        if active_temporary_address is not None:
            try:
                latest = load_state(state_path)
                remove_fixture(latest, active_temporary_address)
                write_state(state_path, latest)
                progress(args, f"discover interrupted; removed temporary fixture-{active_temporary_address}")
            except Exception as exc:
                print(f"amaran: discover interrupted; failed to remove temporary fixture-{active_temporary_address}: {exc}", file=sys.stderr)
        raise

    print_discover_output(args, found, misses, source_relocation)


if __name__ == "__main__":
    main()
