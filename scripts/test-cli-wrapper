{
  "mesh": {
    "uuid": "joined-test-mesh",
    "net_key": "$NET_KEY_SENTINEL",
    "app_key": "$APP_KEY_SENTINEL",
    "iv_index": 0
  },
  "fixtures": [
    {
      "name": "joined-control",
      "node_address": 4,
      "mac_address": "A4:C1:38:99:88:77",
      "code": "400M5",
      "element_count": 1
    }
  ],
  "runtime": {
    "sequence_next": 7
  }
}
JSON
