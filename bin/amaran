node = provisioning.get("node_address")
print("" if node in (None, "") else node)
PY
}

native_onboard_state_path_check() {
  /usr/bin/python3 - "$STATE_PATH" "$ADD_FIXTURE" <<'PY'
import json
import os
import shutil
import sys
import tempfile

state_path = os.path.abspath(os.path.expanduser(sys.argv[1]))
add_to_existing = sys.argv[2] == "1"
parent = os.path.dirname(state_path) or "."
parent = os.path.abspath(parent)

def emit(**kwargs):
    base = {
        "state_path": state_path,
        "add_to_existing_state": add_to_existing,
        "state_path_available": False,
        "state_path_writable": False,
        "blocked_by_existing_state": False,
        "blocked_by_missing_state": False,
        "existing_fixture_count": None,
        "parent_path": parent,
        "parent_exists": os.path.isdir(parent),
    }
    base.update(kwargs)
    print(json.dumps(base))

def is_hex_bytes(value, byte_count):
    if not isinstance(value, str):
        return False
    value = value.strip()
    return len(value) == byte_count * 2 and all(ch in "0123456789abcdefABCDEF" for ch in value)

def int_in_range(value, minimum, maximum):
    try:
        parsed = int(value)
    except (TypeError, ValueError):
        return False
    return minimum <= parsed <= maximum

def validate_existing_payload(payload):
    if not isinstance(payload, dict):
        raise ValueError("state file must contain a JSON object")
    if payload.get("schema_version") != 1:
        raise ValueError(f"unsupported state schema version: {payload.get('schema_version')}")
    mesh = payload.get("mesh")
    fixtures = payload.get("fixtures")
    runtime = payload.get("runtime")
    if not isinstance(mesh, dict):
        raise ValueError("state file is missing mesh data")
    if not isinstance(fixtures, list) or not fixtures:
        raise ValueError("state file is missing fixtures data")
    if not isinstance(runtime, dict):
        raise ValueError("state file is missing runtime data")
    if not mesh.get("uuid"):
        raise ValueError("state mesh data missing field: uuid")
    if not is_hex_bytes(mesh.get("net_key"), 16):
        raise ValueError("state mesh data has invalid net_key")
    if not is_hex_bytes(mesh.get("app_key"), 16):
        raise ValueError("state mesh data has invalid app_key")
    if not int_in_range(runtime.get("iv_index"), 0, 0xFFFFFFFF):
        raise ValueError("state runtime data has invalid iv_index")
    if not int_in_range(runtime.get("source_address"), 1, 0x7FFF):
        raise ValueError("state runtime data has invalid source_address")
    if not int_in_range(runtime.get("telink_source_address"), 1, 0x7FFF):
        raise ValueError("state runtime data has invalid telink_source_address")
    if not int_in_range(runtime.get("sequence_next"), 0, 0x00FFFFFE):
        raise ValueError("state runtime data has invalid sequence_next")
    for index, fixture in enumerate(fixtures, start=1):
        if not isinstance(fixture, dict):
            raise ValueError(f"state fixture #{index} must be a JSON object")
        if not int_in_range(fixture.get("node_address"), 1, 0x7FFF):
            raise ValueError(f"state fixture #{index} has invalid node_address")
        if not is_hex_bytes(fixture.get("device_key"), 16):
            raise ValueError(f"state fixture #{index} has invalid device_key")
        if not is_hex_bytes(fixture.get("device_uuid"), 16):
            raise ValueError(f"state fixture #{index} has invalid device_uuid")
    return fixtures

def probe_parent_writable():
    if not os.path.isdir(parent):
        return False, "state parent path does not exist"
    try:
        fd, probe_path = tempfile.mkstemp(prefix=".amaran-state-write-test.", dir=parent)
        os.close(fd)
        os.unlink(probe_path)
        return True, None
    except Exception as exc:
        return False, str(exc)

if add_to_existing:
    if not os.path.exists(state_path):
        emit(blocked_by_missing_state=True, error="state file does not exist")
        sys.exit(0)
    if not os.path.isfile(state_path):
        emit(error="state path exists and is not a file")
        sys.exit(0)
    try:
        with open(state_path, "r", encoding="utf-8") as fh:
            payload = json.load(fh)
        fixtures = validate_existing_payload(payload)
    except json.JSONDecodeError as exc:
        emit(error=f"state file is invalid JSON at line {exc.lineno} column {exc.colno}")
        sys.exit(0)
    except Exception as exc:
        emit(error=str(exc))
        sys.exit(0)
    writable, error = probe_parent_writable()
    if not writable:
        emit(error=error or "state parent path is not writable")
        sys.exit(0)
    emit(
        state_path_available=True,
        state_path_writable=True,
        existing_fixture_count=len(fixtures),
    )
    sys.exit(0)

if os.path.exists(state_path):
    emit(
        blocked_by_existing_state=True,
        error="state file already exists",
    )
    sys.exit(0)

if os.path.exists(parent) and not os.path.isdir(parent):
    emit(error="state parent path exists and is not a directory")
    sys.exit(0)

cursor = parent
while not os.path.exists(cursor):
    next_cursor = os.path.dirname(cursor)
    if next_cursor == cursor:
        break
    cursor = next_cursor

if not os.path.isdir(cursor):
    emit(error="no writable parent directory found")
    sys.exit(0)

temp_root = None
try:
    if os.path.isdir(parent):
        probe_dir = parent
    else:
        temp_root = tempfile.mkdtemp(prefix=".amaran-state-preflight.", dir=cursor)
        relative_parent = os.path.relpath(parent, cursor)
        probe_dir = os.path.join(temp_root, relative_parent)
        os.makedirs(probe_dir, exist_ok=True)

    fd, probe_path = tempfile.mkstemp(prefix=".amaran-state-write-test.", dir=probe_dir)
    os.close(fd)
    os.unlink(probe_path)
    emit(
        state_path_available=True,
        state_path_writable=True,
        parent_creatable=not os.path.isdir(parent),
    )
except Exception as exc:
    emit(error=str(exc))
finally:
    if temp_root:
        shutil.rmtree(temp_root, ignore_errors=True)
PY
}

print_onboard_state_path_unavailable() {
  local check_json="$1"
  STATE_PATH_CHECK_JSON="$check_json" /usr/bin/python3 - "$JSON" <<'PY'
import json
import os
import sys

raw_json = sys.argv[1] == "1"
check = json.loads(os.environ["STATE_PATH_CHECK_JSON"])
blocked = bool(check.get("blocked_by_existing_state"))
missing = bool(check.get("blocked_by_missing_state"))
adding = bool(check.get("add_to_existing_state"))
state_path = check.get("state_path")
error = check.get("error") or "state path is not writable"
if adding and missing:
    next_step = "run ./bin/amaran pair first to create studio state, or remove --add"
elif adding:
    next_step = "repair or install a valid writable state before adding a fixture"
elif blocked:
    next_step = "use ./bin/amaran pair --add to add a fixture to this studio state, or set --state-path for a separate mesh"
else:
    next_step = "choose a writable --state-path before pairing"
data = dict(check)
data.update({
    "ready": False,
    "unprovisioned_count": None,
    "next_step": next_step,
})

if raw_json:
    print(json.dumps(data, indent=2))
else:
    if adding and missing:
        print(f"pair add preflight: missing existing state at {state_path}")
    elif adding:
        print(f"pair add preflight: state is not usable at {state_path}")
        print(f"error: {error}")
    elif blocked:
        print(f"pair preflight: existing studio state at {state_path}")
    else:
        print(f"pair preflight: state path is not writable at {state_path}")
        print(f"error: {error}")
    print(f"next: {next_step}")
PY
}

ensure_native_onboard_state_path_available() {
  local context="${1:-pairing}"
  local check_json
  check_json="$(native_onboard_state_path_check)"
  STATE_PATH_CHECK_JSON="$check_json" /usr/bin/python3 - "$context" <<'PY'
import json
import os
import sys

context = sys.argv[1]
check = json.loads(os.environ["STATE_PATH_CHECK_JSON"])
if check.get("state_path_available") and check.get("state_path_writable"):
    sys.exit(0)

state_path = check.get("state_path")
if check.get("add_to_existing_state") and check.get("blocked_by_missing_state"):
    print(
        f"amaran: existing state is required at {state_path} before adding a fixture; "
        "run pair once without --add to create studio state",
        file=sys.stderr,
    )
elif check.get("add_to_existing_state"):
    detail = check.get("error") or "state path is not writable"
    print(
        f"amaran: existing state is not usable at {state_path} ({detail}); "
        "repair or install valid state before adding a fixture",
        file=sys.stderr,
    )
elif check.get("blocked_by_existing_state"):
    print(
        f"amaran: state file already exists at {state_path}; "
        f"pass --add to append a fixture or set --state-path before {context}",
        file=sys.stderr,
    )
else:
    detail = check.get("error") or "state path is not writable"
    print(
        f"amaran: state path is not writable at {state_path} ({detail}); "
        f"choose a writable --state-path before {context}",
        file=sys.stderr,
    )
sys.exit(1)
PY
}

run_native_onboard_preflight() {
  local state_check_json
  state_check_json="$(native_onboard_state_path_check)"
  if ! STATE_PATH_CHECK_JSON="$state_check_json" /usr/bin/python3 - <<'PY'
import json
import os
import sys

check = json.loads(os.environ["STATE_PATH_CHECK_JSON"])
sys.exit(0 if check.get("state_path_available") and check.get("state_path_writable") else 1)
PY
  then
    print_onboard_state_path_unavailable "$state_check_json"
    return 0
  fi

  local scan_json
  local error_output
  error_output="$(mktemp -t amaran-pair-preflight-error)"
  if ! scan_json="$(capture_native_json run_native_provision_scan 2>"$error_output")"; then
    cat "$error_output" >&2
    rm -f "$error_output"
    return 1
  fi
  rm -f "$error_output"

  SCAN_JSON="$scan_json" STATE_PATH_CHECK_JSON="$state_check_json" /usr/bin/python3 - "$JSON" "$STATE_PATH" <<'PY'
import json
import os
import sys

raw_json, state_path = sys.argv[1] == "1", os.path.expanduser(sys.argv[2])
state_check = json.loads(os.environ["STATE_PATH_CHECK_JSON"])
scan = json.loads(os.environ["SCAN_JSON"])
discoveries = scan.get("discoveries") or []
count = len(discoveries)
ready = count > 0
adding = bool(state_check.get("add_to_existing_state"))
existing_count = state_check.get("existing_fixture_count")
if ready and adding:
    next_step = "run ./bin/amaran pair --add to append and configure the unprovisioned fixture"
elif ready:
    next_step = "run ./bin/amaran pair to provision and configure the unprovisioned fixture"
elif adding:
    next_step = "factory-reset a fixture or bring an unprovisioned fixture nearby, then rerun pair --add --dry-run"
else:
    next_step = "factory-reset a fixture or bring an unprovisioned fixture nearby, then rerun pair --dry-run"
data = dict(state_check)
data.update({
    "state_path": state_path,
    "state_path_available": True,
    "state_path_writable": True,
    "ready": ready,
    "unprovisioned_count": count,
    "central_state": scan.get("central_state"),
    "next_step": next_step,
    "scan": scan,
})

if raw_json:
    print(json.dumps(data, indent=2))
else:
    device_word = "fixture" if count == 1 else "fixtures"
    if adding:
        print(f"pair add preflight: existing studio state at {state_path}")
        print(f"existing fixtures {existing_count}")
    else:
        print(f"pair preflight: state path available at {state_path}")
    print("state path writable yes")
    print(f"bluetooth {scan.get('central_state', 'unknown')}, {count} unprovisioned {device_word}")
    print(f"ready {'yes' if ready else 'no'}")
    print(f"next: {data['next_step']}")
PY
}

run_native_onboard_test() {
  if [[ "$DRY_RUN" == "1" ]]; then
    run_native_onboard_preflight
    return
  fi

  if ! ensure_native_onboard_state_path_available "pairing"; then
    return 1
  fi

  local provision_json
  local configure_json
  local verify_json

  if ! provision_json="$(capture_native_json run_native_provision_test)"; then
    return 1
  fi
  local provisioned_node_id
  provisioned_node_id="$(node_id_from_provision_json "$provision_json")"
  if [[ -n "$provisioned_node_id" ]]; then
    NODE_ID="$provisioned_node_id"
  fi

  if [[ "$JSON" == "1" ]]; then
    sleep 3
    if ! configure_json="$(capture_native_configure_json_with_retry)"; then
      return 1
    fi
    if [[ "$VERIFY" == "1" ]]; then
      if ! verify_json="$(capture_native_json run_native_status_app status)"; then
        return 1
      fi
      PROVISION_JSON="$provision_json" CONFIGURE_JSON="$configure_json" VERIFY_JSON="$verify_json" /usr/bin/python3 - <<'PY'
import json
import os

print(json.dumps({
    "provision": json.loads(os.environ["PROVISION_JSON"]),
    "configure": json.loads(os.environ["CONFIGURE_JSON"]),
    "verify": json.loads(os.environ["VERIFY_JSON"]),
}, indent=2))
PY
    else
      PROVISION_JSON="$provision_json" CONFIGURE_JSON="$configure_json" /usr/bin/python3 - <<'PY'
import json
import os

print(json.dumps({
    "provision": json.loads(os.environ["PROVISION_JSON"]),
    "configure": json.loads(os.environ["CONFIGURE_JSON"]),
}, indent=2))
PY
    fi
    return
  fi

  print_native_provision_summary_from_json "$provision_json"
  echo "waiting for Mesh Proxy..."
  sleep 3
  if run_native_configure_with_retry; then
    if [[ "$VERIFY" == "1" ]]; then
      echo "verifying status..."
      if run_native_status_app status; then
        echo "pairing complete"
        return 0
      fi

      echo "amaran: pairing configured state, but status verification failed; retry ./bin/amaran status --state-path \"$STATE_PATH\"" >&2
      return 1
    fi

    echo "pairing complete"
    return 0
  fi

  echo "amaran: provisioning completed, but configuration failed; retry ./bin/amaran configure-test" >&2
  return 1
}

run_native_proxy_test() {
  local output
  output="$(mktemp -t amaran-proxy-test)"

  launch_app "$NATIVE_APP" --output "$output" --timeout "$TIMEOUT" --proxy-test

  if [[ ! -s "$output" ]]; then
    rm -f "$output"
    echo "amaran: proxy test did not write a result" >&2
    exit 1
  fi

  /usr/bin/python3 - "$JSON" "$output" <<'PY'
import json
import sys

raw_json, output = sys.argv[1] == "1", sys.argv[2]
with open(output, "r", encoding="utf-8") as fh:
    payload = json.load(fh)

if not payload.get("ok"):
    print(f"amaran: {payload.get('error', 'proxy test failed')}", file=sys.stderr)
    sys.exit(1)

data = payload.get("data", {})
if raw_json:
    print(json.dumps(data, indent=2))
else:
    write = data.get("proxy_write", {})
    status = "completed" if write.get("completed") else "not completed"
    print(
        f"proxy write {status}: "
        f"{write.get('bytes', 0)} bytes to {write.get('characteristic', '2ADD')}, "
        f"notifications {write.get('notification_count', 0)}"
    )
PY
  local helper_status=$?
  rm -f "$output"
  return "$helper_status"
}

run_native_sig_onoff_test() {
  local value="$1"
  local output
  output="$(mktemp -t amaran-sig-onoff-test)"
  local args=(--output "$output" --timeout "$TIMEOUT" --state-path "$STATE_PATH" --sig-onoff-test "$value")
  if [[ -n "$NODE_ID" ]]; then
    args+=(--node "$NODE_ID")
  fi

  launch_app "$NATIVE_APP" "${args[@]}"

  if [[ ! -s "$output" ]]; then
    rm -f "$output"
    echo "amaran: SIG on/off test did not write a result" >&2
    exit 1
  fi

  /usr/bin/python3 - "$JSON" "$output" <<'PY'
import json
import sys

raw_json, output = sys.argv[1] == "1", sys.argv[2]
with open(output, "r", encoding="utf-8") as fh:
    payload = json.load(fh)

if not payload.get("ok"):
    print(f"amaran: {payload.get('error', 'SIG on/off test failed')}", file=sys.stderr)
    sys.exit(1)

data = payload.get("data", {})
if raw_json:
    print(json.dumps(data, indent=2))
else:
    write = data.get("proxy_write", {})
    native = data.get("native_send", {})
    state = "on" if native.get("onoff") else "off"
    print(
        f"SIG on/off test sent {state}: "
        f"address {native.get('address')}, "
        f"sequence {native.get('sequence')}, "
        f"notifications {write.get('notification_count', 0)}"
    )
PY
  local helper_status=$?
  rm -f "$output"
  return "$helper_status"
}

build_native_control_spec() {
  local action="$1"
  case "$action" in
    on|off)
      NATIVE_CONTROL_SPEC="$action"
      ;;
    intensity)
      [[ $# -ge 2 ]] || { echo "amaran: control-test intensity requires a value from 0 to 100" >&2; exit 1; }
      NATIVE_CONTROL_SPEC="intensity:$2"
      ;;
    cct)
      [[ $# -ge 2 ]] || { echo "amaran: control-test cct requires a kelvin value" >&2; exit 1; }
      [[ -n "$INTENSITY_OPT" ]] || { echo "amaran: control-test cct requires --intensity <0-100>" >&2; exit 1; }
      NATIVE_CONTROL_SPEC="cct:$2:$INTENSITY_OPT:10:0"
      ;;
    *)
      echo "amaran: control-test requires on, off, intensity, or cct" >&2
      exit 1
      ;;
  esac
}

run_native_control_app() {
  local spec="$1"
  local output_style="${2:-test}"
  local output
  output="$(mktemp -t amaran-control-test)"
  local args=(--output "$output" --timeout "$TIMEOUT" --state-path "$STATE_PATH" --control-test "$spec")
  if [[ -n "$NODE_ID" ]]; then
    args+=(--node "$NODE_ID")
  fi

  launch_app "$NATIVE_APP" "${args[@]}"

  if [[ ! -s "$output" ]]; then
    rm -f "$output"
    echo "amaran: control test did not write a result" >&2
    exit 1
  fi

  /usr/bin/python3 - "$JSON" "$output_style" "$output" <<'PY'
import json
import sys

raw_json, output_style, output = sys.argv[1] == "1", sys.argv[2], sys.argv[3]
with open(output, "r", encoding="utf-8") as fh:
    payload = json.load(fh)

if not payload.get("ok"):
    data = payload.get("data", {})
    detail = payload.get("error")
    if not detail and data.get("central_state"):
        detail = f"control test failed (central_state {data['central_state']})"
    if not detail:
        detail = "control test failed"
    print(f"amaran: {detail}", file=sys.stderr)
    sys.exit(1)

data = payload.get("data", {})
if raw_json or output_style == "json":
    print(json.dumps(data, indent=2))
elif output_style == "test":
    write = data.get("proxy_write", {})
    native = data.get("native_send", {})
    command = native.get("control_command", "control")
    print(
        f"control test sent {command}: "
        f"address {native.get('address')}, "
        f"sequence {native.get('sequence')}, "
        f"notifications {write.get('notification_count', 0)}"
    )
PY
  local helper_status=$?
  rm -f "$output"
  return "$helper_status"
}

run_native_control_test() {
  build_native_control_spec "$@"
  run_native_control_app "$NATIVE_CONTROL_SPEC" test
}

run_native_status_app() {
  local output_style="${1:-status}"
  local output
  output="$(mktemp -t amaran-status-test)"
  local args=(--output "$output" --timeout "$TIMEOUT" --state-path "$STATE_PATH" --status-test)
  if [[ -n "$NODE_ID" ]]; then
    args+=(--node "$NODE_ID")
  fi

  launch_app "$NATIVE_APP" "${args[@]}"

  if [[ ! -s "$output" ]]; then
    rm -f "$output"
    echo "amaran: status did not write a result" >&2
    return 1
  fi

  /usr/bin/python3 - "$JSON" "$output_style" "$output" <<'PY'
import json
import sys

raw_json, output_style, output = sys.argv[1] == "1", sys.argv[2], sys.argv[3]
with open(output, "r", encoding="utf-8") as fh:
    payload = json.load(fh)

if not payload.get("ok"):
    data = payload.get("data", {})
    detail = payload.get("error")
    if not detail and data.get("central_state"):
        detail = f"status failed (central_state {data['central_state']})"
    if not detail:
        detail = "status failed"
    print(f"amaran: {detail}", file=sys.stderr)
    sys.exit(1)

data = payload.get("data", {})
if raw_json and output_style == "test":
    print(json.dumps(data, indent=2))
    sys.exit(0)

cct = None
telink_status = None
for notification in data.get("proxy_notifications", []):
    telink = notification.get("access", {}).get("telink", {})
    if "cct" in telink:
        cct = telink["cct"]
        telink_status = telink
        break

if not cct:
    print("amaran: status returned no CCT packet", file=sys.stderr)
    sys.exit(1)

native = data.get("native_send", {})
telink_status = telink_status or {}
status = {
    "address": native.get("address"),
    "menu": {
        "type": {
            "name": "CCT",
            "value": 0,
        },
    },
    "cct": {
        "sleep_mode": cct.get("sleep_mode"),
        "reserve": cct.get("reserve"),
        "cct_flag": cct.get("cct_flag"),
        "gm_flag": cct.get("gm_flag"),
        "gm_high": cct.get("gm_high"),
        "gm": cct.get("gm_decoded"),
        "cct": cct.get("cct_decoded"),
        "intensity": cct.get("intensity"),
        "check_sum": telink_status.get("check_sum"),
        "command_type": telink_status.get("command_type"),
        "opera_type": telink_status.get("opera_type"),
    },
}
status["cct"] = {key: value for key, value in status["cct"].items() if value is not None}

if raw_json:
    print(json.dumps(status, indent=2))
    sys.exit(0)

parts = [f"address {native.get('address')}"]
if cct.get("intensity") is not None:
    parts.append(f"intensity {cct['intensity'] / 10:g}%")
if cct.get("cct_kelvin") is not None:
    parts.append(f"cct {cct['cct_kelvin']}K")
if "sleep_mode" in cct:
    parts.append(f"sleep_mode {cct['sleep_mode']}")
print(", ".join(parts))
PY
  local helper_status=$?
  rm -f "$output"
  return "$helper_status"
}

run_native_status_test() {
  run_native_status_app test
}

run_native_configure_test() {
  local composition_json
  local appkey_list_json
  local appkey_add_json
  local model_bind_json
  local has_appkey_zero

  if [[ "$JSON" == "1" ]]; then
    if ! composition_json="$(capture_native_json run_native_config_composition_get_test)"; then
      return 1
    fi
    if ! appkey_list_json="$(capture_native_json run_native_config_appkey_get_test)"; then
      return 1
    fi
    if ! has_appkey_zero="$(native_json_has_appkey_index "$appkey_list_json" 0)"; then
      return 1
    fi
    if [[ "$has_appkey_zero" == "1" ]]; then
      appkey_add_json='{"skipped":true,"reason":"app_key_index_present","app_key_index":0}'
    else
      if ! appkey_add_json="$(capture_native_json run_native_config_appkey_add_test)"; then
        return 1
      fi
    fi
    if ! model_bind_json="$(capture_native_json run_native_config_model_app_bind_test)"; then
      return 1
    fi
    print_native_configure_json "$composition_json" "$appkey_list_json" "$appkey_add_json" "$model_bind_json"
    return
  fi

  run_native_config_composition_get_test || return 1
  if ! appkey_list_json="$(capture_native_json run_native_config_appkey_get_test)"; then
    return 1
  fi
  print_native_appkey_list_summary "$appkey_list_json" || return 1
  if ! has_appkey_zero="$(native_json_has_appkey_index "$appkey_list_json" 0)"; then
    return 1
  fi
  if [[ "$has_appkey_zero" == "1" ]]; then
    echo "Config AppKey Add skipped: app_key_index 0 already present"
  else
    run_native_config_appkey_add_test || return 1
  fi
  run_native_config_model_app_bind_test || return 1
  echo "configuration complete"
}

native_configure_retry_attempts() {
  local attempts="${AMARAN_CONFIGURE_ATTEMPTS:-3}"
  case "$attempts" in
    <->)
      if (( attempts > 0 )); then
        print -r -- "$attempts"
        return
      fi
      ;;
  esac
  print -r -- "3"
}

native_configure_retry_delay() {
  local delay="${AMARAN_CONFIGURE_RETRY_DELAY:-5}"
  case "$delay" in
    <->|<->.<->)
      print -r -- "$delay"
      return
      ;;
  esac
  print -r -- "5"
}

run_native_configure_with_retry() {
  local max_attempts
  local delay
  local attempt=1
  local status
  max_attempts="$(native_configure_retry_attempts)"
  delay="$(native_configure_retry_delay)"

  while true; do
    if run_native_configure_test; then
      return 0
    fi
    status=$?
    if (( attempt >= max_attempts )); then
      return "$status"
    fi
    echo "amaran: configuration attempt $attempt failed; retrying in ${delay}s..." >&2
    sleep "$delay"
    attempt=$(( attempt + 1 ))
  done
}

capture_native_configure_json_with_retry() {
  local max_attempts
  local delay
  local attempt=1
  local status
  local captured
  local error_output
  max_attempts="$(native_configure_retry_attempts)"
  delay="$(native_configure_retry_delay)"

  while true; do
    error_output="$(mktemp -t amaran-configure-error)"
    if captured="$(capture_native_json run_native_configure_test 2>"$error_output")"; then
      rm -f "$error_output"
      print -r -- "$captured"
      return 0
    fi
    status=$?
    if [[ -s "$error_output" ]]; then
      cat "$error_output" >&2
    fi
    rm -f "$error_output"
    if (( attempt >= max_attempts )); then
      return "$status"
    fi
    echo "amaran: configuration attempt $attempt failed; retrying in ${delay}s..." >&2
    sleep "$delay"
    attempt=$(( attempt + 1 ))
  done
}

run_native_config_composition_get_test() {
  local output
  output="$(mktemp -t amaran-config-composition-get-test)"
  local args=(--output "$output" --timeout "$TIMEOUT" --state-path "$STATE_PATH" --config-composition-get-test)
  if [[ -n "$NODE_ID" ]]; then
    args+=(--node "$NODE_ID")
  fi

  launch_app "$NATIVE_APP" "${args[@]}"

  if [[ ! -s "$output" ]]; then
    rm -f "$output"
    echo "amaran: Config Composition Data Get test did not write a result" >&2
    exit 1
  fi

  /usr/bin/python3 - "$JSON" "$output" <<'PY'
import json
import sys

raw_json, output = sys.argv[1] == "1", sys.argv[2]
with open(output, "r", encoding="utf-8") as fh:
    payload = json.load(fh)

if not payload.get("ok"):
    print(f"amaran: {payload.get('error', 'Config Composition Data Get test failed')}", file=sys.stderr)
    sys.exit(1)

data = payload.get("data", {})
if raw_json:
    print(json.dumps(data, indent=2))
else:
    native = data.get("native_send", {})
    composition = data.get("composition_data") or {}
    if not composition.get("stored"):
        print("amaran: composition data response was not stored", file=sys.stderr)
        sys.exit(1)
    print(
        "Config Composition Data stored: "
        f"address {native.get('address')}, "
        f"elements {composition.get('element_count')}, "
        f"vendor_models {composition.get('vendor_model_count')}, "
        f"sequence {native.get('sequence')}"
    )
PY
  local helper_status=$?
  rm -f "$output"
  return "$helper_status"
}

run_native_config_appkey_get_test() {
  local output
  output="$(mktemp -t amaran-config-appkey-get-test)"
  local args=(--output "$output" --timeout "$TIMEOUT" --state-path "$STATE_PATH" --config-appkey-get-test)
  if [[ -n "$NODE_ID" ]]; then
    args+=(--node "$NODE_ID")
  fi

  launch_app "$NATIVE_APP" "${args[@]}"

  if [[ ! -s "$output" ]]; then
    rm -f "$output"
    echo "amaran: Config AppKey Get test did not write a result" >&2
    exit 1
  fi

  /usr/bin/python3 - "$JSON" "$output" <<'PY'
import json
import sys

raw_json, output = sys.argv[1] == "1", sys.argv[2]
with open(output, "r", encoding="utf-8") as fh:
    payload = json.load(fh)

if not payload.get("ok"):
    print(f"amaran: {payload.get('error', 'Config AppKey Get test failed')}", file=sys.stderr)
    sys.exit(1)

data = payload.get("data", {})
if raw_json:
    print(json.dumps(data, indent=2))
else:
    native = data.get("native_send", {})
    appkey_list = None
    for notification in data.get("proxy_notifications", []):
        config = ((notification.get("access") or {}).get("config") or {})
        if config.get("message") == "appkey_list":
            appkey_list = config
            break
    if not appkey_list:
        print("amaran: Config AppKey List response was not received", file=sys.stderr)
        sys.exit(1)
    indexes = appkey_list.get("app_key_indexes") or []
    print(
        "Config AppKey List: "
        f"address {native.get('address')}, "
        f"net_key_index {appkey_list.get('net_key_index')}, "
        f"app_key_indexes {','.join(str(item) for item in indexes) if indexes else '(none)'}, "
        f"status {appkey_list.get('status_name')}"
    )
PY
  local helper_status=$?
  rm -f "$output"
  return "$helper_status"
}

