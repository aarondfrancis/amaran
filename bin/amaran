run_native_config_node_reset_preflight() {
  /usr/bin/python3 - "$JSON" "$STATE_PATH" "$NODE_ID" <<'PY'
import json
import os
import sys

raw_json = sys.argv[1] == "1"
state_path = os.path.abspath(os.path.expanduser(sys.argv[2]))
node_id = sys.argv[3]

def fail(message):
    print(f"amaran: {message}", file=sys.stderr)
    sys.exit(1)

def display_path(path):
    home = os.path.expanduser("~")
    path = os.path.abspath(os.path.expanduser(path))
    if path == home:
        return "~"
    if path.startswith(home + os.sep):
        return "~" + path[len(home):]
    return path

def normalize_mac(value):
    return "".join(ch for ch in str(value or "") if ch in "0123456789abcdefABCDEF").upper()

def mac_suffix(value):
    normalized = normalize_mac(value)
    return normalized[-6:] if normalized else ""

def fixture_label(fixture):
    if fixture.get("name"):
        return str(fixture["name"])
    code = fixture.get("code")
    suffix = mac_suffix(fixture.get("mac_address"))
    if code and suffix:
        return f"{code}-{suffix}"
    return suffix or f"fixture-{fixture.get('node_address', 'unknown')}"

def is_hex_bytes(value, byte_count):
    if not isinstance(value, str):
        return False
    value = value.strip()
    return len(value) == byte_count * 2 and all(ch in "0123456789abcdefABCDEF" for ch in value)

def int_in_range(value, minimum, maximum):
    try:
        parsed = int(value)
    except (TypeError, ValueError):
        return None
    if minimum <= parsed <= maximum:
        return parsed
    return None

def occupied_fixture_addresses(fixtures):
    occupied = set()
    for fixture in fixtures:
        if not isinstance(fixture, dict):
            continue
        address = int_in_range(fixture.get("node_address"), 1, 0x7FFF)
        if address is not None:
            occupied.add(address)
    return occupied

def reset_source_address(runtime, fixtures, destination):
    occupied = occupied_fixture_addresses(fixtures)
    existing = runtime.get("source_address")
    if existing is not None:
        parsed = int_in_range(existing, 1, 0x7FFF)
        if parsed is None:
            fail("local state runtime data has invalid source_address")
        if parsed != 1 and parsed != destination and parsed not in occupied:
            return parsed
    if 3 != destination and 3 not in occupied:
        return 3
    for candidate in range(4, 0x8000):
        if candidate != destination and candidate not in occupied:
            return candidate
    if 2 != destination and 2 not in occupied:
        return 2
    fail("could not choose an unused CLI source address for node reset")

if not os.path.isfile(state_path):
    fail(f"local state not found at {state_path}")

try:
    with open(state_path, "r", encoding="utf-8") as fh:
        payload = json.load(fh)
except json.JSONDecodeError as exc:
    fail(f"local state could not be read: invalid JSON at line {exc.lineno} column {exc.colno}")
except OSError as exc:
    fail(f"local state could not be read: {exc}")

if not isinstance(payload, dict) or payload.get("schema_version") != 1:
    fail("local state has unsupported schema")
mesh = payload.get("mesh")
fixtures = payload.get("fixtures")
if not isinstance(mesh, dict) or not isinstance(fixtures, list) or not fixtures:
    fail("local state is missing mesh or fixture data")
if not is_hex_bytes(mesh.get("net_key"), 16) or not is_hex_bytes(mesh.get("app_key"), 16):
    fail("local state mesh keys are missing or invalid")
runtime = payload.get("runtime")
if not isinstance(runtime, dict):
    fail("local state is missing runtime data")
iv_index = int_in_range(runtime.get("iv_index"), 0, 0xFFFFFFFF)
if iv_index is None:
    fail("local state runtime data has invalid iv_index")
sequence_next = int_in_range(runtime.get("sequence_next"), 0, 0x00FFFFFE)
if sequence_next is None:
    fail("local state runtime data has invalid sequence_next")

if node_id:
    try:
        wanted = int(node_id, 0)
    except ValueError:
        fail("--node must be a fixture node address for node reset")
    matches = [fixture for fixture in fixtures if isinstance(fixture, dict) and fixture.get("node_address") == wanted]
    if not matches:
        fail(f"no fixture found for node {node_id}")
    fixture = matches[0]
else:
    candidates = [fixture for fixture in fixtures if isinstance(fixture, dict)]
    if len(candidates) != 1:
        fail("multiple fixtures found; pass --node before node reset")
    fixture = candidates[0]

try:
    address = int(fixture["node_address"])
except (KeyError, TypeError, ValueError):
    fail("selected fixture has invalid node address")
if not 1 <= address <= 0x7FFF:
    fail("selected fixture has non-unicast node address")
if not is_hex_bytes(fixture.get("device_key"), 16):
    fail("selected fixture device key is missing or invalid")
source_address = reset_source_address(runtime, fixtures, address)

summary = {
    "name": fixture_label(fixture),
    "address": address,
    "mac_suffix": mac_suffix(fixture.get("mac_address")),
    "code": fixture.get("code"),
}
data = {
    "dry_run": True,
    "destructive": True,
    "ready": True,
    "state_path": display_path(state_path),
    "fixture": summary,
    "runtime": {
        "iv_index": iv_index,
        "source_address": source_address,
        "sequence_next": sequence_next,
    },
    "next_step": (
        "run ./bin/amaran config-node-reset-test --confirm-reset, "
        "then run pair --dry-run and pair --verify with an alternate --state-path"
    ),
}

if raw_json:
    print(json.dumps(data, indent=2))
else:
    suffix = summary.get("mac_suffix") or "unknown"
    print("Config Node Reset dry run: ready")
    print(f"fixture {summary['name']}\taddress {summary['address']}\t...{suffix}")
    print(f"runtime source {source_address}, sequence_next {sequence_next}")
    print(f"state {data['state_path']}")
    print(f"next: {data['next_step']}")
PY
}

run_native_config_node_reset_test() {
  if [[ "$DRY_RUN" == "1" ]]; then
    run_native_config_node_reset_preflight
    return
  fi

  if [[ "$CONFIRM_RESET" != "1" ]]; then
    echo "amaran: config-node-reset-test is destructive; pass --confirm-reset to reset the fixture" >&2
    return 1
  fi

  local output
  output="$(mktemp -t amaran-config-node-reset-test)"
  local args=(--output "$output" --timeout "$TIMEOUT" --state-path "$STATE_PATH" --config-node-reset-test --confirm-reset)
  if [[ -n "$NODE_ID" ]]; then
    args+=(--node "$NODE_ID")
  fi

  launch_app "$NATIVE_APP" "${args[@]}"

  if [[ ! -s "$output" ]]; then
    rm -f "$output"
    echo "amaran: Config Node Reset test did not write a result" >&2
    exit 1
  fi

  /usr/bin/python3 - "$JSON" "$output" <<'PY'
import json
import sys

raw_json, output = sys.argv[1] == "1", sys.argv[2]
with open(output, "r", encoding="utf-8") as fh:
    payload = json.load(fh)

if not payload.get("ok"):
    print(f"amaran: {payload.get('error', 'Config Node Reset test failed')}", file=sys.stderr)
    sys.exit(1)

data = payload.get("data", {})
if raw_json:
    print(json.dumps(data, indent=2))
else:
    native = data.get("native_send", {})
    status_seen = False
    for notification in data.get("proxy_notifications", []):
        config = ((notification.get("access") or {}).get("config") or {})
        if config.get("message") == "node_reset_status":
            status_seen = True
            break
    print(
        "Config Node Reset sent: "
        f"address {native.get('address')}, "
        f"sequence {native.get('sequence')}, "
        f"status {'received' if status_seen else 'not observed'}"
    )
    print("next: run ./bin/amaran pair --dry-run --state-path <alternate-state-file>")
PY
  local helper_status=$?
  rm -f "$output"
  return "$helper_status"
}

run_native_status_preferred() {
  run_native_status_app status
}

capture_native_status_json() {
  local JSON=1
  run_native_status_app status
}

build_native_cct_spec_from_status() {
  local kelvin="$1"
  local status_json
  local error_output
  error_output="$(mktemp -t amaran-status-error)"
  if ! status_json="$(capture_native_status_json 2>"$error_output")"; then
    cat "$error_output" >&2
    rm -f "$error_output"
    return 1
  fi
  rm -f "$error_output"

  local spec
  local parse_error
  parse_error="$(mktemp -t amaran-status-parse-error)"
  if ! spec="$(STATUS_JSON="$status_json" /usr/bin/python3 - "$kelvin" 2>"$parse_error" <<'PY'
import json
import os
import sys

kelvin = sys.argv[1]
try:
    payload = json.loads(os.environ["STATUS_JSON"])
except (KeyError, json.JSONDecodeError):
    print("amaran: status returned invalid JSON", file=sys.stderr)
    sys.exit(1)

cct = payload.get("cct") or {}
intensity = cct.get("intensity")
if intensity is None:
    print("amaran: status did not include current intensity", file=sys.stderr)
    sys.exit(1)

gm = cct.get("gm", 10)
gm_flag = cct.get("gm_flag", 0)
print(f"cct:{kelvin}:{intensity / 10:g}:{int(gm)}:{int(gm_flag)}")
PY
  )"; then
    cat "$parse_error" >&2
    rm -f "$parse_error"
    return 1
  fi
  rm -f "$parse_error"

  NATIVE_CONTROL_SPEC="$spec"
}

run_native_control_preferred() {
  local spec="$1"
  local output_style="quiet"
  if [[ "$JSON" == "1" ]]; then
    output_style="json"
  fi
  run_native_control_app "$spec" "$output_style"
}

run_control_command() {
  local action="$1"
  shift

  if [[ ! -s "$STATE_PATH" ]]; then
    echo "amaran: control requires local state at $STATE_PATH" >&2
    return 1
  fi

  if [[ "$action" == "cct" && -z "$INTENSITY_OPT" ]]; then
    build_native_cct_spec_from_status "$1"
  else
    build_native_control_spec "$action" "$@"
  fi
  run_native_control_preferred "$NATIVE_CONTROL_SPEC"
}

run_status_command() {
  if [[ ! -s "$STATE_PATH" ]]; then
    echo "amaran: status requires local state at $STATE_PATH" >&2
    return 1
  fi

  run_native_status_preferred
}

run_probe_command() {
  if [[ ! -s "$STATE_PATH" ]]; then
    echo "amaran: probe requires local state at $STATE_PATH" >&2
    return 1
  fi

  run_native_probe_preferred
}

run_list_command() {
  if [[ ! -s "$STATE_PATH" ]]; then
    echo "amaran: list requires local state at $STATE_PATH" >&2
    return 1
  fi

  run_local_state_list
}

case "$COMMAND" in
  doctor)
    run_direct_doctor
    ;;
  pair)
    run_native_onboard_test
    ;;
  gatt-probe)
    run_native_probe
    ;;
  provision-scan)
    run_native_provision_scan
    ;;
  provision-invite-test)
    run_native_provision_invite_test
    ;;
  provision-test)
    run_native_provision_test
    ;;
  join-capture)
    run_native_join_capture
    ;;
  pair-test)
    run_native_onboard_test
    ;;
  proxy-test)
    run_native_proxy_test
    ;;
  sig-onoff-test)
    [[ ${#POSITIONALS[@]} -ge 1 ]] || { echo "amaran: sig-onoff-test requires on or off" >&2; exit 1; }
    case "$POSITIONALS[1]" in
      on|off)
        run_native_sig_onoff_test "$POSITIONALS[1]"
        ;;
      *)
        echo "amaran: sig-onoff-test requires on or off" >&2
        exit 1
        ;;
    esac
    ;;
  control-test)
    [[ ${#POSITIONALS[@]} -ge 1 ]] || { echo "amaran: control-test requires on, off, intensity, or cct" >&2; exit 1; }
    run_native_control_test "${POSITIONALS[@]}"
    ;;
  status-test)
    run_native_status_test
    ;;
  configure-test)
    run_native_configure_test
    ;;
  config-composition-get-test)
    run_native_config_composition_get_test
    ;;
  config-appkey-get-test)
    run_native_config_appkey_get_test
    ;;
  config-appkey-add-test)
    run_native_config_appkey_add_test
    ;;
  config-model-app-bind-test)
    run_native_config_model_app_bind_test
    ;;
  config-node-reset-test)
    run_native_config_node_reset_test
    ;;
  state-install)
    run_state_install
    ;;
  state-join)
    run_state_join
    ;;
  list)
    run_list_command
    ;;
  probe)
    run_probe_command
    ;;
  status)
    run_status_command
    ;;
  on|off)
    run_control_command "$COMMAND"
    [[ "$JSON" == "1" ]] || echo "$COMMAND"
    ;;
  intensity)
    [[ ${#POSITIONALS[@]} -ge 1 ]] || { echo "amaran: intensity requires a value from 0 to 100" >&2; exit 1; }
    run_control_command intensity "$POSITIONALS[1]"
    [[ "$JSON" == "1" ]] || echo "intensity $POSITIONALS[1]%"
    ;;
  cct)
    [[ ${#POSITIONALS[@]} -ge 1 ]] || { echo "amaran: cct requires a kelvin value" >&2; exit 1; }
    if [[ -n "$INTENSITY_OPT" ]]; then
      run_control_command cct "$POSITIONALS[1]" --intensity "$INTENSITY_OPT"
    else
      run_control_command cct "$POSITIONALS[1]"
    fi
    [[ "$JSON" == "1" ]] || echo "cct $POSITIONALS[1]K"
    ;;
  *)
    echo "amaran: unknown direct command: $COMMAND" >&2
    exit 1
    ;;
esac
